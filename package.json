{
  "name": "coldsearch",
  "version": "0.2.0",
  "description": "Unified search CLI - one interface, multiple providers",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "coldsearch": "./dist/cli.js",
    "usearch": "./dist/cli.js"
  },
  "scripts": {
    "clean": "node -e \"import('node:fs/promises').then((fs) => fs.rm('dist', { recursive: true, force: true }))\"",
    "build": "npm run clean && tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test test/*.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "coldsearch",
    "search",
    "cli",
    "tavily",
    "unified"
  ],
  "author": "Patrick MacLyman",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@bitwarden/sdk-napi": "^1.0.0",
    "@iarna/toml": "^2.2.5",
    "@tavily/core": "^0.7.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
